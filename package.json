{
  "name": "obsidian-notepad-for-zotero",
  "version": "1.0.0-beta.1",
  "description": "Open and edit each item's Obsidian vault markdown note directly in the Zotero item pane, and sync your PDF highlights into it.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "author": "acatechnic",
  "homepage": "https://github.com/acatechnic/obsidian-notepad-for-zotero",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acatechnic/obsidian-notepad-for-zotero.git"
  },
  "config": {
    "addonName": "Obsidian Notepad for Zotero",
    "addonID": "obsidian-notepad-for-zotero@acatechnic",
    "addonRef": "obsidian-notepad",
    "addonInstance": "ZON",
    "prefsPrefix": "extensions.zotero-obsidian-notes"
  },
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build",
    "release": "zotero-plugin release",
    "test:zotero": "zotero-plugin test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "dayjs": "^1.11.13",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "chai": "^5.3.3",
    "esbuild": "^0.28.1",
    "vitest": "^2.1.8",
    "zotero-plugin-scaffold": "^0.8.6"
  }
}
